# Test config
APP_ENV=local
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=*

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=abhijithvenu
POSTGRES_PASSWORD=
